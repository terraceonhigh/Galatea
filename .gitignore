.env
.DS_Store
.commitmsg.tmp

# Built CLI binary (built ad hoc with `go build ./cmd/galatea`)
/galatea
/galatea-bin

# Ad-hoc NFS mountpoint used when testing `galatea serve` live.
/galatea-mnt

# Local-only working clones of third-party FOSS repositories. Daedalus
# reads and lifts from these; they do not enter Galatea's git tree.
# The README is tracked; the actual clones are not.
references/*
!references/README.md

# The visibility covenant, enforced in code. The agent's marginalia are written
# for the agent; the whole directory is local-only and never enters the published
# tree. Only the README (the convention doc) is tracked. The `visible:` flag then
# governs only the reading covenant — whether the Architect reads an entry — not
# whether the world can. Same pattern as references/ above.
atelier/marginalia/*
!atelier/marginalia/README.md
